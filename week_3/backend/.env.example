# Ollama service URL — use http://host.docker.internal:11434 if running Docker without compose
OLLAMA_HOST=http://localhost:11434

# Default LLM model (must be pulled in Ollama first)
DEFAULT_MODEL=llama3.1:latest

# Optional: Gemini API key for cloud models
GEMINI_API_KEY=

# Path to the week 1 jobs SQLite database
DB_PATH=/data/jobs.db
